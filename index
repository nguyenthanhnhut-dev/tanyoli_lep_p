<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root {
    --ink: #0d0c1a;
    --paper: #faf8f3;
    --lotus: #c9975a;
    --lotus-light: #e8c88a;
    --deep: #1a1730;
    --mist: #8a8499;
    --glow: rgba(201,151,90,0.15);
    --border: rgba(201,151,90,0.3);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--ink);
    color: var(--paper);
    font-family: 'Be Vietnam Pro', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background texture */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 80%, rgba(26,23,48,0.9) 0%, transparent 70%),
      radial-gradient(ellipse 50% 60% at 80% 20%, rgba(201,151,90,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 80% 80% at 50% 50%, #0d0c1a 0%, #10102a 100%);
    pointer-events: none; z-index: 0;
  }

  /* Lotus mandala background */
  body::after {
    content: '';
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(201,151,90,0.04) 0%, transparent 70%);
    border: 1px solid rgba(201,151,90,0.05);
    border-radius: 50%;
    pointer-events: none; z-index: 0;
    box-shadow:
      0 0 0 60px rgba(201,151,90,0.02),
      0 0 0 120px rgba(201,151,90,0.015),
      0 0 0 200px rgba(201,151,90,0.01);
  }

  .container {
    position: relative; z-index: 1;
    max-width: 780px;
    margin: 0 auto;
    padding: 0 24px;
    min-height: 100vh;
    display: flex; flex-direction: column;
  }

  /* === HEADER === */
  .site-header {
    padding: 48px 0 32px;
    text-align: center;
    border-bottom: 1px solid var(--border);
  }

  .ornament {
    font-family: 'Cormorant Garamond', serif;
    color: var(--lotus);
    font-size: 14px;
    letter-spacing: 6px;
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0.8;
  }

  .site-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 6vw, 56px);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin-bottom: 10px;
  }

  .site-title em {
    font-style: italic;
    color: var(--lotus-light);
  }

  .site-subtitle {
    font-size: 14px;
    color: var(--mist);
    letter-spacing: 1px;
    font-weight: 300;
  }

  /* === PROGRESS === */
  .progress-wrap {
    padding: 28px 0;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .progress-label {
    font-size: 12px;
    color: var(--lotus);
    letter-spacing: 2px;
    text-transform: uppercase;
    white-space: nowrap;
    min-width: 90px;
  }

  .progress-bar-bg {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--lotus), var(--lotus-light));
    border-radius: 2px;
    transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
    width: 0%;
  }

  .progress-count {
    font-size: 13px;
    color: var(--mist);
    white-space: nowrap;
  }

  /* === SECTIONS === */
  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .section-num {
    width: 32px; height: 32px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px;
    color: var(--lotus);
    font-family: 'Cormorant Garamond', serif;
  }

